# OpenRouter (chat + summarize)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Supabase Auth (required for cloud accounts)
# Without these, the app uses local browser accounts for sign-in / sign-up.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional backend API
VITE_API_BASE_URL=/api

# --- Integrations (required for live sync) ---
# Google Meet / Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud console redirect URI, e.g. http://localhost:5173/api/integrations/oauth/callback
GOOGLE_REDIRECT_URI=

# Notion internal integration token
NOTION_API_KEY=

# Slack bot token (xoxb-…) — invite bot to channels you want to sync
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
